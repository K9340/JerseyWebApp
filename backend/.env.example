# Express Server Configuration
PORT=5000
NODE_ENV=development

# PostgreSQL Connection String (local fallback db name is: jersey_db)
# Local postgres format: postgresql://username:password@localhost:5432/database_name
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/jersey_db

# Secret token key used for signing JWT login profiles
JWT_SECRET=your_custom_jwt_secret_signing_key_here
