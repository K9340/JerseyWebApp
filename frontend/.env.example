# Google Sign-In Credentials configuration
# Create a local '.env' file in this folder and paste your keys:

EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-google-web-client-id-here.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your-google-android-client-id-here.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-google-ios-client-id-here.apps.googleusercontent.com

# Backend API Endpoint URL (for production hosting on Vercel)
EXPO_PUBLIC_API_URL=https://your-backend-service.onrender.com/api
